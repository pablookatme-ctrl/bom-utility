<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp 
  xmlns="http://schemas.microsoft.com/office/appshere/manifest/1.1" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" 
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" 
  xsi:type="TaskPaneApp">

  <!-- 1. 애드인 기본 정보 설정 -->
  <Id>6b3a5c18-80f2-4f9e-9b7e-07fa483fbc3d</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>MyCompany</ProviderName>
  <DefaultLocale>ko-KR</DefaultLocale>
  <DisplayName DefaultValue="BOM Utility" />
  <Description DefaultValue="M365 Excel BOM 자동 그룹화 및 색상 관리 도구입니다." />
  <IconUrl DefaultValue="https://appsforoffice.microsoft.com/assets/images/ux-icons/icon-32.png" />
  <SupportUrl DefaultValue="https://pablookatme-ctrl.github.io/bom-utility" />

  <!-- 작동할 엑셀 종류 설정 -->
  <Hosts>
    <Host Name="Workbook" />
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://pablookatme-ctrl.github.io/bom-utility/taskpane.html" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>

  <!-- 2. 리본 메뉴 버튼 및 UI 정의 -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <!-- 에러 방지를 위해 ID에서 마침표(.)를 제거하고 순수 알파벳으로 변경 -->
              <Group id="BOMGroup">
                <Label DefaultValue="BOM 도구" />
                <Control xsi:type="Button" id="BOMButton">
                  <Label DefaultValue="BOM Utility 실행" />
                  <Supertip>
                    <Title DefaultValue="BOM Utility 실행" />
                    <Description DefaultValue="클릭하면 화면 오른쪽에 BOM 관리 창이 열립니다." />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16" />
                    <bt:Image size="32" resid="Icon32" />
                    <bt:Image size="80" resid="Icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>BOMTaskpane</TaskpaneId>
                    <SourceLocation resid="TaskUrl" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon16" DefaultValue="https://appsforoffice.microsoft.com/assets/images/ux-icons/icon-16.png" />
        <bt:Image id="Icon32" DefaultValue="https://appsforoffice.microsoft.com/assets/images/ux-icons/icon-32.png" />
        <bt:Image id="Icon80" DefaultValue="https://appsforoffice.microsoft.com/assets/images/ux-icons/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="TaskUrl" DefaultValue="https://pablookatme-ctrl.github.io/bom-utility/taskpane.html" />
      </bt:Urls>
    </Resources>
  </VersionOverrides>
</OfficeApp>
